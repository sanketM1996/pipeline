pipeline {
    agent any

    environment {
        MAVEN_HOME = tool 'MAVEN'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git credentialsId: 'git_creds',
                branch: 'main',
                url: 'https://github.com/sanketM1996/SuperLabCode.git'
            }
        }

        stage('Maven Build') {
            steps {
                echo 'Building project'
                bat "${MAVEN_HOME}\\bin\\mvn clean verify -Dtest=!FormUITest"
            }
        }

    }

    post {
        success {
            echo '✅ Build pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed. Please check the logs.'
        }
    }
}